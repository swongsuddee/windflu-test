{
  "name": "windflu-test",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "scripts": {
    "format": "prettier --write .",
    "format:check": "prettier --check .",
    "lint": "eslint .",
    "lint:fix": "eslint . --fix",
    "test": "playwright test",
    "test:web": "playwright test --project=web-ui-unauthenticated --project=web-ui-authenticated",
    "test:web:unauthenticated": "playwright test --project=web-ui-unauthenticated",
    "test:web:authenticated": "playwright test --project=web-ui-authenticated",
    "test:api": "playwright test src/test/api",
    "test:headed": "playwright test --headed",
    "report": "playwright show-report"
  },
  "devDependencies": {
    "@playwright/test": "^1.59.1",
    "@types/node": "^25.6.0",
    "eslint": "^9.39.4",
    "eslint-plugin-playwright": "^2.10.2",
    "prettier": "^3.8.3",
    "typescript": "^5.9.3",
    "typescript-eslint": "8.44.1"
  }
}
